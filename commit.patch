+
+  @override
+  Widget build(BuildContext context) {
+    return BlocBuilder<DashboardCubit, DashboardState>(
+      builder: (context, state) {
+        if (state.isLoading) {
+          return const Scaffold(
+            backgroundColor: Color(0xFFF4F6F9),
+            body: Center(
+              child: CircularProgressIndicator(color: Color(0xFF00A86B)),
+            ),
+          );
+        }
+        return Scaffold(
+          backgroundColor: const Color(0xFFF4F6F9),
+          body: LayoutBuilder(
+            builder: (context, constraints) {
+              final isTablet = constraints.maxWidth < 1100;
+              return Row(
+                children: [
+                  Sidebar(isCompact: isTablet),
+                  Expanded(
+                    child: Column(
+                      children: [
+                        TopBar(title: _titleFor(state.selectedNav)),
+                        Expanded(
+                          child: _buildBody(state, isTablet),
+                        ),
+                      ],
+                    ),
+                  ),
+                ],
+              );
+            },
+          ),
+        );
+      },
+    );
+  }
+
+  String _titleFor(NavItem nav) {
+    switch (nav) {
+      case NavItem.rider:
+        return 'Rider Management';
+      case NavItem.drivers:
+        return 'Driver Management';
+      case NavItem.payments:
+        return 'Payments';
+      case NavItem.analytics:
+        return 'Analytics';
+      case NavItem.support:
+        return 'Support Center';
+      case NavItem.settings:
+        return 'System Settings';
+      default:
+        return 'Dashboard';
+    }
+  }
+
+  Widget _buildBody(DashboardState state, bool isTablet) {
+    switch (state.selectedNav) {
+      case NavItem.rider:
+        return const RiderScreen();
+      default:
+        return _DashboardBody(isTablet: isTablet);
+    }
+  }
