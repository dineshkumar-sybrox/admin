+            const Column(
+              children: [
+                DemandMapWidget(),
+                SizedBox(height: 16),
+                DocumentApprovalsPanel(),
+              ],
+            )
+          else
+            const Row(
+              crossAxisAlignment: CrossAxisAlignment.start,
+              children: [
+                Expanded(flex: 3, child: DemandMapWidget()),
+                SizedBox(width: 16),
+                Expanded(flex: 2, child: DocumentApprovalsPanel()),
+              ],
+            ),
+          const SizedBox(height: 20),
